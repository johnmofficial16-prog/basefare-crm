{
    "name": "basefare/crm",
    "description": "Base Fare Custom CRM System",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "slim/slim": "4.*",
        "slim/psr7": "^1.6",
        "illuminate/database": "^10.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "slim/slim": true
        }
    }
}
